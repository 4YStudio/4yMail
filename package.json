{
  "name": "4ymail",
  "version": "1.0.3",
  "description": "A modern, glassmorphism-style email client.",
  "author": "Henvei",
  "private": true,
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "NODE_ENV=development electron .",
    "electron:build": "vite build && electron-builder --linux --win"
  },
  "dependencies": {
    "vue": "^3.5.29",
    "imapflow": "^1.0.171",
    "nodemailer": "^6.10.1",
    "mailparser": "^3.7.2"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.4",
    "electron": "^34.2.0",
    "electron-builder": "^25.1.8",
    "vite": "^7.3.1",
    "vite-plugin-vue-devtools": "^8.0.6"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  },
  "build": {
    "appId": "com.4ymail.app",
    "productName": "4yMail",
    "icon": "public/logo.png",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Network",
      "icon": "public/logo.png"
    },
    "win": {
      "target": [
        "portable",
        "nsis"
      ],
      "icon": "public/logo.png"
    }
  }
}